# iSolarCloud Portal Giriş Ayarları
ISOLAR_BASE_URL=https://www.isolarcloud.com/
ISOLAR_USERNAME=your_username_here
ISOLAR_PASSWORD=your_password_here
ISOLAR_HEADLESS=true

# Dizin Yapılandırması
LOG_DIR=logs
RAW_EXPORTS_DIR=outputs/raw_exports
REPORT_OUTPUT_DIR=outputs/pdf
CHART_OUTPUT_DIR=outputs/charts

# Uygulama Ortamı (development, production)
APP_ENV=production

# Veritabanı Yapılandırması
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/solar_report_db

# SMTP E-Posta Yapılandırması
SMTP_ENABLED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=true

# Dashboard Yapılandırması
DASHBOARD_PORT=8080
DASHBOARD_ACCESS_MODE=localhost
